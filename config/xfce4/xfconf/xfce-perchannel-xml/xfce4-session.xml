<?xml version="1.0" encoding="UTF-8"?>
<!-- XFCE Session Configuration for KubeTTY -->
<!-- Disables session-level power/lock features -->

<channel name="xfce4-session" version="1.0">
  <!-- Disable session locking -->
  <property name="general" type="empty">
    <property name="LockCommand" type="string" value=""/>
    <property name="AutoSave" type="bool" value="false"/>
    <property name="SaveOnExit" type="bool" value="false"/>
  </property>

  <!-- Disable shutdown/suspend prompts -->
  <property name="shutdown" type="empty">
    <property name="LockScreen" type="bool" value="false"/>
  </property>
</channel>
