#!/bin/bash
#
# pre-commit hook - Fast validation checks before allowing commits
#
# This hook runs quickly (<15 seconds) to provide immediate feedback.
# Install with: git config core.hooksPath .githooks
#
# Checks performed:
# 1. Forbidden file patterns (secrets, keys, credentials)
# 2. Go formatting (gofmt) - if Go is available
# 3. Go linting (go vet) - if Go is available
# 4. Go mod tidiness - if Go is available
# 5. Merge conflict markers

set -eu

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the root of the repository
REPO_ROOT=$(git rev-parse --show-toplevel)

# Cleanup function for temporary files
cleanup() {
    rm -f "$REPO_ROOT/server/go.mod.bak" "$REPO_ROOT/server/go.sum.bak" 2>/dev/null || true
}
trap cleanup EXIT

print_error() {
    echo -e "${RED}[pre-commit] ERROR: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}[pre-commit] $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}[pre-commit] WARNING: $1${NC}"
}

# Check if Go is available
HAS_GO=false
if command -v go &>/dev/null; then
    HAS_GO=true
fi

# Track if any check fails
FAILED=0

#
# Check 1: Forbidden file patterns
#
echo "[pre-commit] Checking for forbidden files..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Forbidden patterns - files that should never be committed
# These patterns are specific to avoid false positives
FORBIDDEN_PATTERNS=(
    # Private keys and certificates
    '\.key$'
    '\.pem$'
    '\.p12$'
    '\.pfx$'
    '\.p8$'
    '\.jks$'
    '\.keystore$'
    # Secret files (not .example variants)
    '\.secrets\.yaml$'
    '\.secrets\.yml$'
    # Environment files (excluding .example)
    '^\.env$'
    '\.env\.local$'
    '\.env\.production$'
    '\.env\.staging$'
    '\.env\.development$'
    # Credential files
    'credentials\.json$'
    'service-account\.json$'
    'kubeconfig$'
    '\.kube/config$'
    # SSH keys
    'id_rsa$'
    'id_ed25519$'
    'id_ecdsa$'
    'id_dsa$'
    '\.ssh/.*_key$'
    # Cloud credentials
    '\.aws/credentials$'
    '\.gcp/credentials\.json$'
)

for file in $STAGED_FILES; do
    for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
            print_error "Forbidden file detected: $file"
            print_error "Files matching pattern '$pattern' should not be committed"
            FAILED=1
        fi
    done
done

if [ $FAILED -eq 0 ]; then
    print_success "No forbidden files detected"
fi

#
# Check 2: Go formatting (only if Go is available)
#
if [ -d "$REPO_ROOT/server" ]; then
    echo "[pre-commit] Checking Go formatting..."

    # Get staged Go files under server/
    STAGED_GO_FILES=$(echo "$STAGED_FILES" | grep '^server/.*\.go$' || true)

    if [ -n "$STAGED_GO_FILES" ]; then
        if [ "$HAS_GO" = true ]; then
            cd "$REPO_ROOT/server"

            # Check formatting of staged files only
            UNFORMATTED=""
            for file in $STAGED_GO_FILES; do
                # Convert from repo-relative path (server/foo.go) to server-relative path (foo.go)
                rel_file="${file#server/}"
                if [ -f "$REPO_ROOT/$file" ]; then
                    result=$(gofmt -l "$rel_file" 2>&1) || true
                    if [ -n "$result" ]; then
                        UNFORMATTED="$UNFORMATTED$file\n"
                    fi
                fi
            done

            if [ -n "$UNFORMATTED" ]; then
                print_error "The following Go files are not formatted:"
                echo -e "$UNFORMATTED"
                echo ""
                echo "Run: cd server && gofmt -w ."
                FAILED=1
            else
                print_success "Go files are properly formatted"
            fi

            cd "$REPO_ROOT"
        else
            print_warning "Go not installed - skipping gofmt check"
        fi
    else
        print_success "No Go files staged (skipping gofmt)"
    fi
fi

#
# Check 3: Go vet (only if Go files are staged and Go is available)
#
if [ -d "$REPO_ROOT/server" ]; then
    STAGED_GO_FILES=$(echo "$STAGED_FILES" | grep '^server/.*\.go$' || true)

    if [ -n "$STAGED_GO_FILES" ]; then
        if [ "$HAS_GO" = true ]; then
            echo "[pre-commit] Running go vet..."
            cd "$REPO_ROOT/server"

            if ! go vet ./... 2>&1; then
                print_error "go vet found issues"
                FAILED=1
            else
                print_success "go vet passed"
            fi

            cd "$REPO_ROOT"
        else
            print_warning "Go not installed - skipping go vet"
        fi
    fi
fi

#
# Check 4: Go mod tidiness (only if go.mod or go.sum changed and Go is available)
#
if [ -d "$REPO_ROOT/server" ]; then
    GO_MOD_CHANGED=$(echo "$STAGED_FILES" | grep -E '^server/(go\.mod|go\.sum)$' || true)

    if [ -n "$GO_MOD_CHANGED" ]; then
        if [ "$HAS_GO" = true ]; then
            echo "[pre-commit] Checking go.mod tidiness..."
            cd "$REPO_ROOT/server"

            # Backup current files
            cp go.mod go.mod.bak 2>/dev/null || true
            cp go.sum go.sum.bak 2>/dev/null || true

            go mod tidy 2>&1

            # Check if go mod tidy changed anything
            if ! diff -q go.mod go.mod.bak >/dev/null 2>&1 || ! diff -q go.sum go.sum.bak >/dev/null 2>&1; then
                # Restore original files
                mv go.mod.bak go.mod 2>/dev/null || true
                mv go.sum.bak go.sum 2>/dev/null || true
                print_error "go.mod or go.sum is not tidy"
                echo ""
                echo "Run: cd server && go mod tidy"
                FAILED=1
            else
                rm -f go.mod.bak go.sum.bak 2>/dev/null || true
                print_success "go.mod is tidy"
            fi

            cd "$REPO_ROOT"
        else
            print_warning "Go not installed - skipping go.mod tidy check"
        fi
    fi
fi

#
# Check 5: Merge conflict markers
#
echo "[pre-commit] Checking for merge conflict markers..."

CONFLICT_FILES=""
for file in $STAGED_FILES; do
    if [ -f "$REPO_ROOT/$file" ]; then
        # Check for conflict markers
        if grep -qE '^(<<<<<<<|=======|>>>>>>>)' "$REPO_ROOT/$file" 2>/dev/null; then
            CONFLICT_FILES="$CONFLICT_FILES$file\n"
        fi
    fi
done

if [ -n "$CONFLICT_FILES" ]; then
    print_error "Merge conflict markers found in:"
    echo -e "$CONFLICT_FILES"
    FAILED=1
else
    print_success "No merge conflict markers found"
fi

#
# Final result
#
echo ""
if [ $FAILED -ne 0 ]; then
    print_error "Pre-commit checks failed. Please fix the issues above."
    echo ""
    echo "Emergency bypass: git commit --no-verify"
    echo "Note: CI/CD pipeline will still enforce these checks."
    exit 1
fi

print_success "All pre-commit checks passed!"
exit 0
